<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>This is forget password page</h1>

    <input type="password" id="password"  placeholder="enter a new password">
    <button onclick="handleSubmit()">submit</button>
    <!-- <p> <%= token %> </p> -->

    <script>
        let token = '<%= token %>'


        let passwordTag = document.getElementById('password')

        async function handleSubmit(){
            let obj = {
                password:passwordTag.value
            }
            console.log(obj)

            let res = await fetch(`http://localhost:8090/users/updatePassword/${token}`,{
                method:"put",
                headers:{
                    'content-type':'application/json'
                },
                body:JSON.stringify(obj)
            })

            let data = await res.json();
            console.log(data) //{msg:"password updated successfully"}
            alert(data.msg)
        }

    </script>
</body>
</html>